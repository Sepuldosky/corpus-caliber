"UnlitGeneric"
{
	"$basetexture" "models\shield\overshield"
	"$nodecal" "1"
	"$model" "1"
	"$additive" "1"
	"$nocull" "1"

        
	 "Proxies"
        {
                "AnimatedTexture"
                {
                         "animatedtexturevar" "$basetexture"
                         "animatedtextureframenumvar" "$frame"
                         "animatedtextureframerate" 30
                }
                "TextureScroll"
		{
			"texturescrollvar" "$basetexturetransform"
			"texturescrollrate" 1
			"texturescrollangle" 45
		}
        }

}
